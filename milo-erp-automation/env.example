# ========================================
# CONFIGURACIÓN DEL ERP HGI
# ========================================

# URL base del API del HGI
HGI_API_URL=https://900405097.hginet.com.co

# Credenciales de acceso al HGI
HGI_USUARIO=tu_usuario
HGI_PASSWORD=tu_contraseña

# Endpoints del HGI (no cambiar, ya están correctos)
HGI_ENDPOINT_EMPLEADOS=/ip_servicios_web/Api/Empleados/Obtener
HGI_ENDPOINT_VENDEDORES=/ip_servicios_web/Api/Vendedores/Obtener
HGI_ENDPOINT_PRODUCTOS=/ip_servicios_web/Api/Productos/ObtenerProductos
HGI_ENDPOINT_PEDIDOS=/ip_servicios_web/Api/Documentos/ObtenerDocumentos
HGI_ENDPOINT_CLIENTES=/ip_servicios_web/Api/Terceros/ObtenerLista

# ========================================
# CONFIGURACIÓN DE GOOGLE SHEETS (OPCIONAL)
# ========================================

# ID de tu Google Sheet
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Credenciales de Google Service Account (JSON)
# Obtén esto desde: https://console.cloud.google.com/
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"tu_proyecto","private_key_id":"tu_key_id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"tu_email@tu_proyecto.iam.gserviceaccount.com"}

# ========================================
# SEGURIDAD
# ========================================

# Secret para cron jobs
CRON_SECRET=tu_secret_super_seguro_aleatorio

# ========================================
# CONFIGURACIÓN DE SINCRONIZACIÓN
# ========================================

# Frecuencia de sincronización (en minutos)
SYNC_INTERVAL=10

# Retener logs de sincronización (en horas)
LOG_RETENTION_HOURS=24
